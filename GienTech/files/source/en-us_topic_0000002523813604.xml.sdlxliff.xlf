        <target state="new" state-qualifier="fuzzy-match"/>
      </trans-unit>
      <trans-unit id="6" ns:sid="2047271444642066438" ns:tid="2047271763192000519" translate="yes" ns:wfId="2047222835224051714" ns:wfName="T" ns:originTarget="" ns:Status="New" ns:Origin="" ns:MatchRate="49">
        <source>If the PV power is just enough to meet the load demand, the system may prioritize the load, and there is no surplus power for charging the battery.</source>
        <target state="new" state-qualifier="fuzzy-match"/>
      </trans-unit>
      <trans-unit id="7" ns:sid="2047271444642066439" ns:tid="2047271763192000520" translate="no" ns:wfId="2047222835224051714" ns:wfName="T" ns:originTarget="" ns:Status="New" ns:Origin="REP" ns:MatchRate="100">
