        <source><bpt id="g0">&lt;b class=&quot;+ topic/ph hi-d/b &quot; id=&quot;b59078853111285&quot;&gt;</bpt>Backup power SOC protection mechanism<ept id="g0">&lt;/g&gt;</ept>:</source>
        <target state="new" state-qualifier="fuzzy-match"/>
      </trans-unit>
      <trans-unit id="9" ns:sid="2047271444642066441" ns:tid="2047271763192000522" translate="yes" ns:wfId="2047222835224051714" ns:wfName="T" ns:originTarget="" ns:Status="New" ns:Origin="" ns:MatchRate="41">
        <source>To ensure the power supply capability in the event of unexpected power outages, the system sets the peak shaving backup power SOC (for example, 20%) or off-grid backup power SOC (for example, 5%).</source>
        <target state="new" state-qualifier="fuzzy-match"/>
      </trans-unit>
      <trans-unit id="10" ns:sid="2047271444642066442" ns:tid="2047271763192000523" translate="no" ns:wfId="2047222835224051714" ns:wfName="T" ns:originTarget="" ns:Status="New" ns:Origin="REP" ns:MatchRate="100">
        <source>If the battery SOC is lower than this threshold at night, the system prevents the battery from discharging.</source>
        <target state="new" state-qualifier="fuzzy-match"/>
      </trans-unit>
      <trans-unit id="11" ns:sid="2047271444642066443" ns:tid="2047271763192000524" translate="no" ns:wfId="2047222835224051714" ns:wfName="T" ns:originTarget="" ns:Status="New" ns:Origin="REP" ns:MatchRate="100">
        <source><bpt id="g0">&lt;b class=&quot;+ topic/ph hi-d/b &quot; id=&quot;b870675830112953&quot;&gt;</bpt>End-of-discharge SOC<ept id="g0">&lt;/g&gt;</ept>:</source>
        <target state="new" state-qualifier="fuzzy-match"/>
      </trans-unit>
      <trans-unit id="12" ns:sid="2047271444642066444" ns:tid="2047271763192000525" translate="no" ns:wfId="2047222835224051714" ns:wfName="T" ns:originTarget="" ns:Status="New" ns:Origin="REP" ns:MatchRate="100">
        <source>If the battery SOC decreases to the end-of-discharge SOC (for example, 10%), the system forcibly stops discharging to prevent overdischarge.</source>
        <target state="new" state-qualifier="fuzzy-match"/>
      </trans-unit>
      <trans-unit id="13" ns:sid="2047271444642066445" ns:tid="2047271763192000526" translate="yes" ns:wfId="2047222835224051714" ns:wfName="T" ns:originTarget="" ns:Status="New" ns:Origin="" ns:MatchRate="56">
