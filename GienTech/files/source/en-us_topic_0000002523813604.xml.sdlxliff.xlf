      <trans-unit id="4" ns:sid="2047271444642066436" ns:tid="2047271763192000517" translate="yes" ns:wfId="2047222835224051714" ns:wfName="T" ns:originTarget="" ns:Status="New" ns:Origin="" ns:MatchRate="31">
        <source>If this function is enabled, the system dynamically adjusts battery usage based on the electricity price curve and load prediction, and may temporarily not take action to reserve energy for higher-yield periods.</source>
        <target state="new" state-qualifier="fuzzy-match"/>
      </trans-unit>
      <trans-unit id="5" ns:sid="2047271444642066437" ns:tid="2047271763192000518" translate="yes" ns:wfId="2047222835224051714" ns:wfName="T" ns:originTarget="" ns:Status="New" ns:Origin="" ns:MatchRate="49">
