      </trans-unit>
      <trans-unit id="6" ns:sid="2047271450304376839" ns:tid="2047271815876653062" translate="yes" ns:wfId="2047222835224051714" ns:wfName="T" ns:originTarget="" ns:Status="New" ns:Origin="" ns:MatchRate="49">
        <source>Even if irradiance is sufficient, the energy yield will be limited.</source>
        <target state="new" state-qualifier="fuzzy-match"/>
      </trans-unit>
      <trans-unit id="7" ns:sid="2047271450304376840" ns:tid="2047271815876653063" translate="yes" ns:wfId="2047222835224051714" ns:wfName="T" ns:originTarget="Geen teruglevering" ns:Status="New" ns:Origin="" ns:MatchRate="89">
        <source><bpt id="g0">&lt;b class=&quot;+ topic/ph hi-d/b &quot; id=&quot;b193872036588&quot;&gt;</bpt>Zero feed-in<ept id="g0">&lt;/g&gt;</ept>:</source>
        <target state="new" state-qualifier="fuzzy-match">Geen teruglevering</target>
