      <trans-unit id="11" ns:sid="2047271450304376844" ns:tid="2047271815876653067" translate="yes" ns:wfId="2047222835224051714" ns:wfName="T" ns:originTarget="" ns:Status="New" ns:Origin="" ns:MatchRate="21">
        <source>Momentary cloud shading or weather changes at noon may cause irradiance fluctuations and unstable PV current output (for example, a sudden change in irradiance at constant voltage causes a drop in current).</source>
        <target state="new" state-qualifier="fuzzy-match"/>
      </trans-unit>
