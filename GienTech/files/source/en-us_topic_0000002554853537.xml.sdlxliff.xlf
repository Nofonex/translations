      <trans-unit id="8" ns:sid="2047271450304376841" ns:tid="2047271815876653064" translate="yes" ns:wfId="2047222835224051714" ns:wfName="T" ns:originTarget="" ns:Status="New" ns:Origin="" ns:MatchRate="38">
        <source>If the grid connection point power is forcibly set to zero (grid feed-in is prohibited), the PV power is used first to supply local loads, and the remainder may be curtailed by the inverter, causing the energy yield to decline.</source>
        <target state="new" state-qualifier="fuzzy-match"/>
      </trans-unit>
