        <source><bpt id="g0">&lt;b class=&quot;+ topic/ph hi-d/b &quot; id=&quot;b193881336485&quot;&gt;</bpt>Temperature impact<ept id="g0">&lt;/g&gt;</ept>:</source>
        <target state="new" state-qualifier="fuzzy-match"/>
      </trans-unit>
