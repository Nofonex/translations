ic/ph ui-d/uicontrol &quot; id=&quot;uicontrol1891019245456&quot; conref=&quot;en-us_topic_0000207784470567.xml#438333&quot; idp:conrefpath=&quot;200650494000#EN-US_BOOKMAP_0000002298266790#EN-US_TOPIC_0000207784470567&quot;/&gt;" word-end="false">&lt;ph id="f1"&gt;</ph><props><value key="prefix"></value><value key="localName">ph</value><value key="namespaces"></value><value key="isEmptyElement">False</value><value key="nodeType">Element</value><value key="displayText">&lt;uicontrol class="+ topic/ph ui-d/uicontrol " id="uicontrol1891019245456" conref="en-us_topic_0000207784470567.xml#438333" idp:conrefpath="200650494000#EN-US_BOOKMAP_0000002298266790#EN-US_TOPIC_0000207784470567"/&gt;</value><value key="hasDisplayText">True</value><value key="attribute:id">f1</value></props></tag></tag-defs></header><body><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="99f51107-34d9-4c54-99a0-4468ef243b1f"><source>Why Is the Battery Not Charged by PV Power?</source><seg-source><mrk mtype="seg" mid="1">Why Is the Battery Not Charged by PV Power?</mrk></seg-source><target><mrk mtype="seg" mid="1">Waarom wordt de batterij niet opgeladen door PV-vermogen?</mrk></target><sdl:seg-defs><sdl:seg id="1"><sdl:value key="SegmentIdentityHash">XnZY2CvuA3ReM8GApQxHpvRGaTU=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="5656d1c9-48eb-4dd1-894f-edb0c4491a97"><source>Battery SOC policy restrictions</source><seg-source><mrk mtype="seg" mid="2">Battery SOC policy restrictions</mrk></seg-source><target><mrk mtype="seg" mid="2">Beperkingen van het SOC-beleid van de batterij</mrk></target><sdl:seg-defs><sdl:seg id="2"><sdl:value key="SegmentIdentityHash">KFmjDT3q07cJFwjUHK5/fDjzfYY=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="33a05c51-e2bc-46de-aa6c-3390b9893312"><source>When the battery SOC reaches the preset <x id="0" /> (for example, 90%), the system will suspend charging to prevent the risk of overcharging.</source><seg-source><mrk mtype="seg" mid="3">When the battery SOC reaches the preset <x id="0" /> (for example, 90%), the system will suspend charging to prevent the risk of overcharging.</mrk></seg-source><target><mrk mtype="seg" mid="3">Wanneer de SOC van de batterij de vooraf ingestelde <x id="0" /> bereikt (bijvoorbeeld 90%), onderbreekt het systeem het opladen om het risico op overladen te voorkomen.</mrk></target><sdl:seg-defs><sdl:seg id="3"><sdl:value key="SegmentIdentityHash">JJbfeRIV65DeCvMqONtNRwFPG5Q=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="892128f9-9dbd-4e55-b435-38b281ddf6ab"><source>System operating mode conflict</source><seg-source><mrk mtype="seg" mid="4">System operating mode conflict</mrk></seg-source><target><mrk mtype="seg" mid="4">Conflict van systeembedrijfsmodus</mrk></target><sdl:seg-defs><sdl:seg id="4"><sdl:value key="SegmentIdentityHash">Ym8wsQXDIPXzwywJytmOsrXRNl8=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="cddb7143-741d-4448-8c2d-26eb2c3e7c40"><source><x id="1" /> enabled:</source><seg-source><mrk mtype="seg" mid="5"><x id="1" /> enabled:</mrk></seg-source><target><mrk mtype="seg" mid="5">Inschakelen:</mrk></target><sdl:seg-defs><sdl:seg id="5"><sdl:value key="SegmentIdentityHash">I72HSs2sMfH8aEshgjkqjv4MI7s=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="5ea25c12-2a2f-4647-b07a-6083d3328dee"><source>If the <x id="2" /> function is enabled, the system may prioritize selling surplus PV power rather than storing it in the battery.</source><seg-source><mrk mtype="seg" mid="6">If the <x id="2" /> function is enabled, the system may prioritize selling surplus PV power rather than storing it in the battery.</mrk></seg-source><target><mrk mtype="seg" mid="6">Als de functie <x id="2" /> is ingeschakeld, kan het systeem prioriteit geven aan het verkopen van overtollig PV-vermogen in plaats van dit in de batterij op te slaan.</mrk></target><sdl:seg-defs><sdl:seg id="6"><sdl:value key="SegmentIdentityHash">375CArBXhNvGa+cXUTrjJvPGcx8=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="1e5fb664-c6b8-430c-83b8-862ff3113d77"><source><g id="6"><x id="4" /></g><g id="6"> </g><g id="6">mode</g>:</source><seg-source><g id="6"><x id="4" /></g><g id="6"> </g><mrk mtype="seg" mid="7"><g id="6">mode</g>:</mrk></seg-source><target><g id="6"><x id="4" /></g><g id="6"> </g><mrk mtype="seg" mid="7"><g id="6">modus</g>:</mrk></target><sdl:seg-defs><sdl:seg id="7"><sdl:value key="SegmentIdentityHash">Sg9IS6G+V0NbJTn6CvMPCI84Hms=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="bfe7ded2-a479-45fc-857d-39113bb0769b"><source>In <x id="7" /> mode, the system prioritizes using PV power to meet load requirements, and directly sells surplus power rather than storing it in the battery.</source><seg-source><mrk mtype="seg" mid="8">In <x id="7" /> mode, the system prioritizes using PV power to meet load requirements, and directly sells surplus power rather than storing it in the battery.</mrk></seg-source><target><mrk mtype="seg" mid="8">In de modus <x id="7" /> geeft het systeem prioriteit aan het gebruik van PV-vermogen om aan de belastingsvereisten te voldoen en verkoopt het overtollige vermogen rechtstreeks in plaats van dit in de batterij op te slaan.</mrk></target><sdl:seg-defs><sdl:seg id="8"><sdl:value key="SegmentIdentityHash">jwcnnIBbU7nBCnCkspNKRRtgbs0=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="59534cdc-0b0f-4215-ad91-cb7ebcd48adb"><source><g id="11">Incorrect <x id="9" /> mode configuration</g>:</source><seg-source><mrk mtype="seg" mid="9"><g id="11">Incorrect <x id="9" /> mode configuration</g>:</mrk></seg-source><target><mrk mtype="seg" mid="9"><g id="11">Onjuiste configuratie van de modus <x id="9" /></g>:</mrk></target><sdl:seg-defs><sdl:seg id="9"><sdl:value key="SegmentIdentityHash">FoOHY8H9KvfZVpL0ZXVJHjoHpn8=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="b30d6bd5-9559-4dfa-aa39-53dc4c521b6a"><source>If the PV power generation period is not manually set as the charging window, or the charging window does not cover the off-peak electricity price period, the system may not trigger battery charging.</source><seg-source><mrk mtype="seg" mid="10">If the PV power generation period is not manually set as the charging window, or the charging window does not cover the off-peak electricity price period, the system may not trigger battery charging.</mrk></seg-source><target><mrk mtype="seg" mid="10">Als de PV-opwekkingsperiode niet handmatig is ingesteld als laadvenster, of als het laadvenster de periode met lage elektriciteitsprijzen niet dekt, kan het systeem het opladen van de batterij mogelijk niet activeren.</mrk></target><sdl:seg-defs><sdl:seg id="10"><sdl:value key="SegmentIdentityHash">l1vECzppX0C7/xgYke1v6FbOqiY=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="1f9988c5-5bd7-447a-a4ec-2e64bc5eccfb"><source>Economic optimization policy</source><seg-source><mrk mtype="seg" mid="11">Economic optimization policy</mrk></seg-source><target><mrk mtype="seg" mid="11">Economisch optimalisatiebeleid</mrk></target><sdl:seg-defs><sdl:seg id="11"><sdl:value key="SegmentIdentityHash">/jsavHs+6AM8Fzvjhlop4pZi95Q=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="f1deeb58-f182-442b-845c-c5115ee79331"><source><g id="14">Insufficient peak-valley price difference</g>:</source><seg-source><mrk mtype="seg" mid="12"><g id="14">Insufficient peak-valley price difference</g>:</mrk></seg-source><target><mrk mtype="seg" mid="12"><g id="14">Onvoldoende prijsverschil tussen piek en dal</g>:</mrk></target><sdl:seg-defs><sdl:seg id="12"><sdl:value key="SegmentIdentityHash">BzHg2Rhw1BS+JCI8LCV2zjUzLZ0=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="a4bd8844-d100-448a-9cc5-aa88403ea58b"><source>If the difference between the feed-in electricity price (peak hours) and the electricity purchase price (off-peak hours) is small, the system may determine that selling electricity directly is more economical than the charge-discharge cycle.</source><seg-source><mrk mtype="seg" mid="13">If the difference between the feed-in electricity price (peak hours) and the electricity purchase price (off-peak hours) is small, the system may determine that selling electricity directly is more economical than the charge-discharge cycle.</mrk></seg-source><target><mrk mtype="seg" mid="13">Als het verschil tussen de terugleveringsprijs van elektriciteit (piekuren) en de inkoopprijs van elektriciteit (daluren) klein is, kan het systeem bepalen dat het direct verkopen van elektriciteit economischer is dan de laad-ontlaadcyclus.</mrk></target><sdl:seg-defs><sdl:seg id="13"><sdl:value key="SegmentIdentityHash">/NQB0GGF2W8ig/xdYValcU6Sx38=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="bd8ec8b9-5d7e-4b16-9b3d-bcd9534cb0a7"><source>Consequently, the system prioritizes feeding PV power to the grid rather than storing it.</source><seg-source><mrk mtype="seg" mid="14">Consequently, the system prioritizes feeding PV power to the grid rather than storing it.</mrk></seg-source><target><mrk mtype="seg" mid="14">Als gevolg hiervan geeft het systeem prioriteit aan het terugleveren van PV-vermogen aan het net in plaats van dit op te slaan.</mrk></target><sdl:seg-defs><sdl:seg id="14"><sdl:value key="SegmentIdentityHash">U7CjNctqqXGczwAFyUMjbG1s8e0=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="c6bd1bdb-022e-4654-85be-aa871770b1f0"><source><g id="17">Negative electricity price scenario</g>:</source><seg-source><mrk mtype="seg" mid="15"><g id="17">Negative electricity price scenario</g>:</mrk></seg-source><target><mrk mtype="seg" mid="15"><g id="17">Scenario met negatieve elektriciteitsprijs</g>:</mrk></target><sdl:seg-defs><sdl:seg id="15"><sdl:value key="SegmentIdentityHash">iso5S+cmIWr+4GJf9TZsZ7zzKeM=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="cbb62890-ed28-4e99-8981-eaa83d006778"><source>When the electricity purchase price is negative, the system may prioritize purchasing electricity from the grid to charge the battery rather than use PV power.</source><seg-source><mrk mtype="seg" mid="16">When the electricity purchase price is negative, the system may prioritize purchasing electricity from the grid to charge the battery rather than use PV power.</mrk></seg-source><target><mrk mtype="seg" mid="16">Wanneer de inkoopprijs van elektriciteit negatief is, kan het systeem prioriteit geven aan het inkopen van elektriciteit van het net om de batterij op te laden, in plaats van PV-vermogen te gebruiken.</mrk></target><sdl:seg-defs><sdl:seg id="16"><sdl:value key="SegmentIdentityHash">/FB+i/GXuBBtu57/MvZHgb9uDxE=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="81135250-741e-4f74-9d0d-5e0c40ac379b"><source>Energy prediction and scheduling priority:</source><seg-source><mrk mtype="seg" mid="17">Energy prediction and scheduling priority:</mrk></seg-source><target><mrk mtype="seg" mid="17">Prioriteit voor energievoorspelling en planning:</mrk></target><sdl:seg-defs><sdl:seg id="17"><sdl:value key="SegmentIdentityHash">JUHHsLbEpAMet/C808iGT6dCQRc=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="c1e35054-3965-4520-b434-c5c3f6100179"><source>The system uses historical data to forecast future electricity demand and price fluctuations.</source><seg-source><mrk mtype="seg" mid="18">The system uses historical data to forecast future electricity demand and price fluctuations.</mrk></seg-source><target><mrk mtype="seg" mid="18">Het systeem gebruikt historische gegevens om toekomstige elektriciteitsvraag en prijsschommelingen te voorspellen.</mrk></target><sdl:seg-defs><sdl:seg id="18"><sdl:value key="SegmentIdentityHash">/a9gUpRkwLDOgejbGmD3Y0mOpmA=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="c410f215-c872-49b1-b99a-cfa73e653e5d"><source>If the system forecasts that electricity prices will be lower or PV power will be more abundant in the future, it may temporarily suspend charging to wait for a better opportunity (for example, waiting until the electricity price is lower).</source><seg-source><mrk mtype="seg" mid="19">If the system forecasts that electricity prices will be lower or PV power will be more abundant in the future, it may temporarily suspend charging to wait for a better opportunity (for example, waiting until the electricity price is lower).</mrk></seg-source><target><mrk mtype="seg" mid="19">Als het systeem voorspelt dat de elektriciteitsprijzen in de toekomst lager zullen zijn of dat er meer PV-vermogen beschikbaar zal zijn, kan het tijdelijk het opladen onderbreken om te wachten op een betere kans (bijvoorbeeld wachten tot de elektriciteitsprijs lager is).</mrk></target><sdl:seg-defs><sdl:seg id="19"><sdl:value key="SegmentIdentityHash">bHPNjtzJ8/qZ+8+KAhkODmP1+wk=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group></body></file></xliff>