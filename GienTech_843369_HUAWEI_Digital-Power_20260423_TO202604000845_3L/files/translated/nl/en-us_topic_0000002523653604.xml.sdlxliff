Element</value><value key="displayText">&lt;uicontrol conref="en-us_topic_0000207635068088.xml#144641" class="+ topic/ph ui-d/uicontrol " id="uicontrol11342165875711"/&gt;</value><value key="hasDisplayText">True</value><value key="attribute:id">f0</value></props></tag><tag id="4"><ph name="&lt;uicontrol class=&quot;+ topic/ph ui-d/uicontrol &quot; conref=&quot;en-us_topic_0000207784935935.xml#460689&quot; idp:conrefpath=&quot;200650494000#EN-US_BOOKMAP_0000002298267098#EN-US_TOPIC_0000207784935935&quot; id=&quot;uicontrol148042863091557&quot;/&gt;" word-end="false">&lt;ph id="f0"&gt;</ph><props><value key="prefix"></value><value key="localName">ph</value><value key="namespaces"></value><value key="isEmptyElement">False</value><value key="nodeType">Element</value><value key="displayText">&lt;uicontrol class="+ topic/ph ui-d/uicontrol " conref="en-us_topic_0000207784935935.xml#460689" idp:conrefpath="200650494000#EN-US_BOOKMAP_0000002298267098#EN-US_TOPIC_0000207784935935" id="uicontrol148042863091557"/&gt;</value><value key="hasDisplayText">True</value><value key="attribute:id">f0</value></props></tag><tag id="8"><ph name="&lt;uicontrol class=&quot;+ topic/ph ui-d/uicontrol &quot; id=&quot;uicontrol15469169194016&quot; conref=&quot;en-us_topic_0000207634837332.xml#450677&quot; idp:conrefpath=&quot;200650494000#EN-US_BOOKMAP_0000002298266790#EN-US_TOPIC_0000207634837332&quot;/&gt;" word-end="false">&lt;ph id="f1"&gt;</ph><props><value key="prefix"></value><value key="localName">ph</value><value key="namespaces"></value><value key="isEmptyElement">False</value><value key="nodeType">Element</value><value key="displayText">&lt;uicontrol class="+ topic/ph ui-d/uicontrol " id="uicontrol15469169194016" conref="en-us_topic_0000207634837332.xml#450677" idp:conrefpath="200650494000#EN-US_BOOKMAP_0000002298266790#EN-US_TOPIC_0000207634837332"/&gt;</value><value key="hasDisplayText">True</value><value key="attribute:id">f1</value></props></tag></tag-defs></header><body><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="2ce1e4a5-5245-483b-ac3f-ab8eb0767690"><source>Why Is the Battery Not Fully Charged?</source><seg-source><mrk mtype="seg" mid="1">Why Is the Battery Not Fully Charged?</mrk></seg-source><target><mrk mtype="seg" mid="1">Waarom is de batterij niet volledig opgeladen?</mrk></target><sdl:seg-defs><sdl:seg id="1"><sdl:value key="SegmentIdentityHash">V+AgILxFAwyoFNtqRR/vDoU2lOE=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="03a51c29-cb84-462b-b66a-de93e40fd881"><source>Operating mode restrictions</source><seg-source><mrk mtype="seg" mid="2">Operating mode restrictions</mrk></seg-source><target><mrk mtype="seg" mid="2">Bedrijfsmodus</mrk></target><sdl:seg-defs><sdl:seg id="2"><sdl:rep id="Yc18EA/Q9GEJRpzkJlatR+uRjJA=" /><sdl:value key="SegmentIdentityHash">Yc18EA/Q9GEJRpzkJlatR+uRjJA=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="e4f7e8aa-411d-4f18-8d5f-60de79ade938"><source>If the <x id="0" /> mode is selected, the system allows only surplus PV power to charge the battery and prohibits charging from the grid.</source><seg-source><mrk mtype="seg" mid="3">If the <x id="0" /> mode is selected, the system allows only surplus PV power to charge the battery and prohibits charging from the grid.</mrk></seg-source><target><mrk mtype="seg" mid="3">Als de modus <x id="0" /> is geselecteerd, staat het systeem alleen toe dat overtollig PV-vermogen de batterij oplaadt en verbiedt het opladen vanaf het net.</mrk></target><sdl:seg-defs><sdl:seg id="3"><sdl:value key="SegmentIdentityHash">fo1EU2LOFEv+Rigz2oqt9s9+oDA=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="21dfbbca-8ce8-40f2-89e3-dd919b0f9aad"><source>In <x id="1" /> mode, you need to manually set the low electricity price period as the charging period.</source><seg-source><mrk mtype="seg" mid="4">In <x id="1" /> mode, you need to manually set the low electricity price period as the charging period.</mrk></seg-source><target><mrk mtype="seg" mid="4">In de modus <x id="1" /> moet u de periode met lage elektriciteitsprijzen handmatig instellen als oplaadperiode.</mrk></target><sdl:seg-defs><sdl:seg id="4"><sdl:value key="SegmentIdentityHash">aCIL7fCe5ehkNQfyzcbcnPWj4zE=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="cdda5dd4-fa88-426c-ab87-48b40146de99"><source>Function switch status</source><seg-source><mrk mtype="seg" mid="5">Function switch status</mrk></seg-source><target><mrk mtype="seg" mid="5">Status schakelaar</mrk></target><sdl:seg-defs><sdl:seg id="5"><sdl:rep id="tl9kB4a1a43HGsqWwhwgeY+n/jI=" /><sdl:value key="SegmentIdentityHash">tl9kB4a1a43HGsqWwhwgeY+n/jI=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="f4c736f8-8a39-4c13-af7d-94516b94253e"><source>The <x id="2" /> function is disabled by default.</source><seg-source><mrk mtype="seg" mid="6">The <x id="2" /> function is disabled by default.</mrk></seg-source><target><mrk mtype="seg" mid="6">De functie is standaard uitgeschakeld.</mrk></target><sdl:seg-defs><sdl:seg id="6"><sdl:rep id="QK03W2M+OakGcLHMaMZHnrKnpiY=" /><sdl:value key="SegmentIdentityHash">QK03W2M+OakGcLHMaMZHnrKnpiY=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="f4527bf2-ac53-4bcf-b190-65ff553c1606"><source>You need to manually enable it to charge the battery at a low electricity price.</source><seg-source><mrk mtype="seg" mid="7">You need to manually enable it to charge the battery at a low electricity price.</mrk></seg-source><target><mrk mtype="seg" mid="7">U moet dit handmatig inschakelen om de batterij op te laden bij een lage elektriciteitsprijs.</mrk></target><sdl:seg-defs><sdl:seg id="7"><sdl:rep id="gRBVB9RLSXw3I+8GkKAW7IuMra4=" /><sdl:value key="SegmentIdentityHash">gRBVB9RLSXw3I+8GkKAW7IuMra4=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="e39b1d9c-3e63-4f6b-b67e-d6fe74d68200"><source>System parameter settings</source><seg-source><mrk mtype="seg" mid="8">System parameter settings</mrk></seg-source><target><mrk mtype="seg" mid="8">Instellingen systeemparameter</mrk></target><sdl:seg-defs><sdl:seg id="8"><sdl:rep id="xqlVPIqapJSGfXGI+tQZGFBlOMk=" /><sdl:value key="SegmentIdentityHash">xqlVPIqapJSGfXGI+tQZGFBlOMk=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="00a5f2cc-0d20-47ed-98d4-977ed756a754"><source>The <x id="3" /> is set too low (for example, 80%).</source><seg-source><mrk mtype="seg" mid="9">The <x id="3" /> is set too low (for example, 80%).</mrk></seg-source><target><mrk mtype="seg" mid="9">De <x id="3" /> is te laag ingesteld (bijvoorbeeld 80%).</mrk></target><sdl:seg-defs><sdl:seg id="9"><sdl:rep id="8XsQkxHsv5W/l3xhWMbpbxO5WaM=" /><sdl:value key="SegmentIdentityHash">8XsQkxHsv5W/l3xhWMbpbxO5WaM=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="87f4cf1d-416d-4554-bb4e-d0aa55e043a7"><source>When the threshold is reached, charging stops.</source><seg-source><mrk mtype="seg" mid="10">When the threshold is reached, charging stops.</mrk></seg-source><target><mrk mtype="seg" mid="10">Wanneer de drempelwaarde is bereikt, stopt het opladen.</mrk></target><sdl:seg-defs><sdl:seg id="10"><sdl:rep id="eXu+h3y0ZCdfHQY/NRqfCV4bBAs=" /><sdl:value key="SegmentIdentityHash">eXu+h3y0ZCdfHQY/NRqfCV4bBAs=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="c3afc772-f1cf-4aca-bee7-8c231d3207d5"><source>Reserve the <x id="4" /> for peak shaving, stopping charging in advance.</source><seg-source><mrk mtype="seg" mid="11">Reserve the <x id="4" /> for peak shaving, stopping charging in advance.</mrk></seg-source><target><mrk mtype="seg" mid="11">Reserveer de <x id="4" /> voor piekbelastingafvlakking, waarbij het opladen van tevoren wordt gestopt.</mrk></target><sdl:seg-defs><sdl:seg id="11"><sdl:rep id="pFdr6hxDSWuRwB3UAeA4NWoloeI=" /><sdl:value key="SegmentIdentityHash">pFdr6hxDSWuRwB3UAeA4NWoloeI=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="0b2f7604-8ea9-455f-a775-b4566b22fde7"><source>The <g id="7">Maximum charge power</g> parameter is set to an excessively low value or the <x id="8" /> function is also enabled.</source><seg-source><mrk mtype="seg" mid="12">The <g id="7">Maximum charge power</g> parameter is set to an excessively low value or the <x id="8" /> function is also enabled.</mrk></seg-source><target><mrk mtype="seg" mid="12">De parameter <g id="7">Maximaal oplaadvermogen</g> is ingesteld op een te lage waarde of de functie <x id="8" /> is ook ingeschakeld.</mrk></target><sdl:seg-defs><sdl:seg id="12"><sdl:value key="SegmentIdentityHash">EnWLueevrImheyfCl2qikeijAJE=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group></body></file></xliff>