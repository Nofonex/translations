2"><bpt name="&lt;uicontrol class=&quot;+ topic/ph ui-d/uicontrol &quot; id=&quot;uicontrol4455295474&quot;&gt;" word-end="false">&lt;bpt id="g0"&gt;</bpt><bpt-props><value key="prefix"></value><value key="localName">bpt</value><value key="namespaces"></value><value key="isEmptyElement">False</value><value key="nodeType">Element</value><value key="displayText">&lt;uicontrol class="+ topic/ph ui-d/uicontrol " id="uicontrol4455295474"&gt;</value><value key="hasDisplayText">True</value><value key="attribute:id">g0</value></bpt-props><ept name="&lt;/g&gt;" word-end="false">&lt;ept id="g0"&gt;</ept><ept-props><value key="prefix"></value><value key="localName">ept</value><value key="namespaces"></value><value key="isEmptyElement">False</value><value key="nodeType">Element</value><value key="displayText">&lt;/g&gt;</value><value key="hasDisplayText">True</value><value key="attribute:id">g0</value></ept-props></tag></tag-defs></header><body><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="7e9f29f7-a572-42fe-a765-8e20ea558166"><source>Why Can't the Battery Meet the Load Requirements When the Electricity Price Is High?</source><seg-source><mrk mtype="seg" mid="1">Why Can't the Battery Meet the Load Requirements When the Electricity Price Is High?</mrk></seg-source><target><mrk mtype="seg" mid="1">Why Can't the Battery Meet the Load Requirements When the Electricity Price Is High?</mrk></target><sdl:seg-defs><sdl:seg id="1" origin="source"><sdl:value key="SegmentIdentityHash">B5vrD/otmCoWqW0cUmF9kDfJUUY=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="76ce562e-f961-439f-ae04-c0fc2d275e57"><source>Power limit</source><seg-source><mrk mtype="seg" mid="2">Power limit</mrk></seg-source><target><mrk mtype="seg" mid="2">Actief-vermogensbegrenzing</mrk></target><sdl:seg-defs><sdl:seg id="2"><sdl:rep id="iyHtoKziaWifRN0Xoi5XwrmPzX4=" /><sdl:value key="SegmentIdentityHash">iyHtoKziaWifRN0Xoi5XwrmPzX4=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="aab8958f-50ce-4a1d-9476-d7c5f0235493"><source>The <g id="2">maximum discharge power</g> of the battery is lower than the load demand.</source><seg-source><mrk mtype="seg" mid="3">The <g id="2">maximum discharge power</g> of the battery is lower than the load demand.</mrk></seg-source><target><mrk mtype="seg" mid="3">The <g id="2">maximum discharge power</g> of the battery is lower than the load demand.</mrk></target><sdl:seg-defs><sdl:seg id="3" origin="source"><sdl:value key="SegmentIdentityHash">a2Umx9Hkyj4MObAiz+FRqASPKkM=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="d35a1485-dfaf-429e-8b14-93652670882a"><source>For example, the load suddenly increases to 8 kW, but the battery supports only 5 kW of discharge.</source><seg-source><mrk mtype="seg" mid="4">For example, the load suddenly increases to 8 kW, but the battery supports only 5 kW of discharge.</mrk></seg-source><target><mrk mtype="seg" mid="4">For example, the load suddenly increases to 8 kW, but the battery supports only 5 kW of discharge.</mrk></target><sdl:seg-defs><sdl:seg id="4" origin="source"><sdl:value key="SegmentIdentityHash">JbYoAeBeUgScfaPTiSZ4JlfpS/0=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="f48e1a00-f54c-4210-b668-f7968c5b6ded"><source>The system responds to load fluctuations in real time.</source><seg-source><mrk mtype="seg" mid="5">The system responds to load fluctuations in real time.</mrk></seg-source><target><mrk mtype="seg" mid="5">The system responds to load fluctuations in real time.</mrk></target><sdl:seg-defs><sdl:seg id="5" origin="source"><sdl:value key="SegmentIdentityHash">U34oPujzWJzM58vdtRZHaTvF+QM=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="62529387-18f7-46f1-b1d7-90cd0bc0f60e"><source>When high-power devices are started simultaneously, the power supply capability of the battery may be exceeded.</source><seg-source><mrk mtype="seg" mid="6">When high-power devices are started simultaneously, the power supply capability of the battery may be exceeded.</mrk></seg-source><target><mrk mtype="seg" mid="6">When high-power devices are started simultaneously, the power supply capability of the battery may be exceeded.</mrk></target><sdl:seg-defs><sdl:seg id="6" origin="source"><sdl:value key="SegmentIdentityHash">ZKWD/vNMDr/Z3t8b7uUqOj+iD1U=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="35cef404-ad2d-4465-98db-86d872ea7db0"><source>SOC threshold settings</source><seg-source><mrk mtype="seg" mid="7">SOC threshold settings</mrk></seg-source><target><mrk mtype="seg" mid="7">SOC threshold settings</mrk></target><sdl:seg-defs><sdl:seg id="7" origin="source"><sdl:value key="SegmentIdentityHash">a4DR24Db259lqpfiu5XTkrsLOx8=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="9f21f331-f5cf-4c36-bb27-d0a203f7c905"><source>If the end-of-discharge SOC is set too high (for example, 50%), the available capacity during high electricity price periods decreases.</source><seg-source><mrk mtype="seg" mid="8">If the end-of-discharge SOC is set too high (for example, 50%), the available capacity during high electricity price periods decreases.</mrk></seg-source><target><mrk mtype="seg" mid="8">If the end-of-discharge SOC is set too high (for example, 50%), the available capacity during high electricity price periods decreases.</mrk></target><sdl:seg-defs><sdl:seg id="8" origin="source"><sdl:value key="SegmentIdentityHash">LW7njFkd95dkSPGn+3AUMHGos8k=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="8595297a-3755-4ca5-9d01-3ccb5e0aead3"><source>To ensure the power supply capability in the event of a power outage, the system forcibly reserves the backup power SOC (usually 5% to 20%)</source><seg-source><mrk mtype="seg" mid="9">To ensure the power supply capability in the event of a power outage, the system forcibly reserves the backup power SOC (usually 5% to 20%)</mrk></seg-source><target><mrk mtype="seg" mid="9">To ensure the power supply capability in the event of a power outage, the system forcibly reserves the backup power SOC (usually 5% to 20%)</mrk></target><sdl:seg-defs><sdl:seg id="9" origin="source"><sdl:value key="SegmentIdentityHash">XMnOjYiDBIKMaZ/K3ec7Qep2Ghs=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="83491185-6541-40ff-93d0-9b035b7bdbd6"><source>Economic policy</source><seg-source><mrk mtype="seg" mid="10">Economic policy</mrk></seg-source><target><mrk mtype="seg" mid="10">Economic policy</mrk></target><sdl:seg-defs><sdl:seg id="10" origin="source"><sdl:value key="SegmentIdentityHash">gPl5oQXxT1HSQz/pW91NwiM1icI=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="0d761b6f-d431-4a51-84ab-11343589aa5f"><source>If the electricity feed-in price remains higher than the electricity purchase price, the system may prioritize selling electricity to the grid instead of supplying power to local loads.</source><seg-source><mrk mtype="seg" mid="11">If the electricity feed-in price remains higher than the electricity purchase price, the system may prioritize selling electricity to the grid instead of supplying power to local loads.</mrk></seg-source><target><mrk mtype="seg" mid="11">If the electricity feed-in price remains higher than the electricity purchase price, the system may prioritize selling electricity to the grid instead of supplying power to local loads.</mrk></target><sdl:seg-defs><sdl:seg id="11" origin="source"><sdl:value key="SegmentIdentityHash">WQN0aFV17RYiGnhqUpIvbRDTsjw=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="f29284a7-1c85-4aa5-bd27-bbb2c84c6cff"><source>The AI algorithm reserves some battery capacity to cope with potentially higher electricity prices.</source><seg-source><mrk mtype="seg" mid="12">The AI algorithm reserves some battery capacity to cope with potentially higher electricity prices.</mrk></seg-source><target><mrk mtype="seg" mid="12">The AI algorithm reserves some battery capacity to cope with potentially higher electricity prices.</mrk></target><sdl:seg-defs><sdl:seg id="12" origin="source"><sdl:value key="SegmentIdentityHash">H8XOdQAgVth9kYs68IkLEZmBJ/s=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="06ed2020-d79f-4f73-9be3-424acfaea2a5"><source>Forecast error</source><seg-source><mrk mtype="seg" mid="13">Forecast error</mrk></seg-source><target><mrk mtype="seg" mid="13">Fout bij voorspelling</mrk></target><sdl:seg-defs><sdl:seg id="13"><sdl:value key="SegmentIdentityHash">fTy8oabSWGZwFgB1aZL/l0E5btQ=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="92a986b0-e099-40ab-a136-52e3eda3225a"><source>Load forecast based on historical data deviates from the actual energy consumption pattern (for example, high-power devices such as air conditioners start unexpectedly at the same time).</source><seg-source><mrk mtype="seg" mid="14">Load forecast based on historical data deviates from the actual energy consumption pattern (for example, high-power devices such as air conditioners start unexpectedly at the same time).</mrk></seg-source><target><mrk mtype="seg" mid="14">Load forecast based on historical data deviates from the actual energy consumption pattern (for example, high-power devices such as air conditioners start unexpectedly at the same time).</mrk></target><sdl:seg-defs><sdl:seg id="14" origin="source"><sdl:value key="SegmentIdentityHash">UM0bMWk+B7tjSp+b2WMBLrGlJmY=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="b0d4ec24-3e33-49b9-bc53-96da4b9b4620"><source>Factors such as sudden weather changes cause the actual energy consumption demand to exceed the forecast range.</source><seg-source><mrk mtype="seg" mid="15">Factors such as sudden weather changes cause the actual energy consumption demand to exceed the forecast range.</mrk></seg-source><target><mrk mtype="seg" mid="15">Factors such as sudden weather changes cause the actual energy consumption demand to exceed the forecast range.</mrk></target><sdl:seg-defs><sdl:seg id="15" origin="source"><sdl:value key="SegmentIdentityHash">lA9yrnVSzdnKCcnH4DbtKD9HlVc=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group></body></file></xliff>