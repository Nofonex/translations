><value key="namespaces"></value><value key="isEmptyElement">False</value><value key="nodeType">Element</value><value key="displayText">&lt;uicontrol class="+ topic/ph ui-d/uicontrol " id="uicontrol181460121618" conref="en-us_topic_0000207634602764.xml#388057" idp:usecustomid="x-wc://file=ZH-CN_TOPIC_0000207634602764.xml#388057" idp:conrefpath="200650494000#EN-US_BOOKMAP_0000002298266790#EN-US_TOPIC_0000207634602764"/&gt;</value><value key="hasDisplayText">True</value><value key="attribute:id">f0</value></props></tag><tag id="13"><ph name="&lt;ph class=&quot;- topic/ph &quot; conref=&quot;en-us_topic_0000001645659009.xml#ph122067484595&quot; id=&quot;ph1959151418587&quot; idp:conrefpath=&quot;200650494000#EN-US_BOOKMAP_0000001596019118#EN-US_TOPIC_0000001645659009&quot; idp:userph=&quot;true&quot;/&gt;" word-end="false">&lt;ph id="f0"&gt;</ph><props><value key="prefix"></value><value key="localName">ph</value><value key="namespaces"></value><value key="isEmptyElement">False</value><value key="nodeType">Element</value><value key="displayText">&lt;ph class="- topic/ph " conref="en-us_topic_0000001645659009.xml#ph122067484595" id="ph1959151418587" idp:conrefpath="200650494000#EN-US_BOOKMAP_0000001596019118#EN-US_TOPIC_0000001645659009" idp:userph="true"/&gt;</value><value key="hasDisplayText">True</value><value key="attribute:id">f0</value></props></tag></tag-defs></header><body><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="8766a221-c9af-4213-9d63-6c25265d8d53"><source>Why Is the PV Output Low When the Irradiance Is Good at Noon?</source><seg-source><mrk mtype="seg" mid="1">Why Is the PV Output Low When the Irradiance Is Good at Noon?</mrk></seg-source><target><mrk mtype="seg" mid="1">Waarom is de PV-opbrengst laag terwijl de zonnestraling rond het middaguur goed is?</mrk></target><sdl:seg-defs><sdl:seg id="1"><sdl:value key="SegmentIdentityHash">uwpkENX2BNa4cUFv6X7wHCup3zA=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="e9e14017-02aa-44c8-9304-ec418760689c"><source>Power limit policy</source><seg-source><mrk mtype="seg" mid="2">Power limit policy</mrk></seg-source><target><mrk mtype="seg" mid="2">Vermogensbegrenzingsbeleid</mrk></target><sdl:seg-defs><sdl:seg id="2"><sdl:value key="SegmentIdentityHash">A+3eP/ty99tENNjMspSonIuPbik=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="d0acb1bc-2908-435a-8333-8f2951b34255"><source><g id="2">Limited feed-in</g>:</source><seg-source><mrk mtype="seg" mid="3"><g id="2">Limited feed-in</g>:</mrk></seg-source><target><mrk mtype="seg" mid="3">Beperkte teruglevering</mrk></target><sdl:seg-defs><sdl:seg id="3"><sdl:value key="SegmentIdentityHash">mlP+mWRXTVATAMcECXqcpjRP65k=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="960628e5-3d45-4e20-a944-65b38995b165"><source>The system may have a <x id="3" /> threshold set.</source><seg-source><mrk mtype="seg" mid="4">The system may have a <x id="3" /> threshold set.</mrk></seg-source><target><mrk mtype="seg" mid="4">Het systeem heeft mogelijk een drempelwaarde <x id="3" /> ingesteld.</mrk></target><sdl:seg-defs><sdl:seg id="4"><sdl:value key="SegmentIdentityHash">GHRYmIunaSXvvtgxmCnlfS5ySxY=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="0f75a854-3e29-419d-9a1a-9e26a4791890"><source>When the PV output exceeds the threshold, the inverter actively reduces the output power.</source><seg-source><mrk mtype="seg" mid="5">When the PV output exceeds the threshold, the inverter actively reduces the output power.</mrk></seg-source><target><mrk mtype="seg" mid="5">Wanneer de PV-opbrengst de drempelwaarde overschrijdt, verlaagt de omvormer actief het uitgangsvermogen.</mrk></target><sdl:seg-defs><sdl:seg id="5"><sdl:value key="SegmentIdentityHash">qVimTGnIXxC1MlmHvkO+WFOO+yU=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="7041d09a-09c3-4808-8c48-a83542a5f02f"><source>Even if irradiance is sufficient, the energy yield will be limited.</source><seg-source><mrk mtype="seg" mid="6">Even if irradiance is sufficient, the energy yield will be limited.</mrk></seg-source><target><mrk mtype="seg" mid="6">Zelfs als de zonnestraling voldoende is, is de energieopbrengst beperkt.</mrk></target><sdl:seg-defs><sdl:seg id="6"><sdl:value key="SegmentIdentityHash">uDuKNl4+H7U71lWVDkc7pUf2frA=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="4fd45d9f-1eeb-4666-bd94-3cfbddfd0086"><source><g id="6">Zero feed-in</g>:</source><seg-source><mrk mtype="seg" mid="7"><g id="6">Zero feed-in</g>:</mrk></seg-source><target><mrk mtype="seg" mid="7">Geen teruglevering</mrk></target><sdl:seg-defs><sdl:seg id="7"><sdl:value key="SegmentIdentityHash">VnOpd9yWKRy6yrum0ruRaviK8Hg=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="bad830db-7245-4541-81dc-22934ae858f3"><source>If the grid connection point power is forcibly set to zero (grid feed-in is prohibited), the PV power is used first to supply local loads, and the remainder may be curtailed by the inverter, causing the energy yield to decline.</source><seg-source><mrk mtype="seg" mid="8">If the grid connection point power is forcibly set to zero (grid feed-in is prohibited), the PV power is used first to supply local loads, and the remainder may be curtailed by the inverter, causing the energy yield to decline.</mrk></seg-source><target><mrk mtype="seg" mid="8">Als het vermogen op het netkoppelpunt geforceerd op nul is ingesteld (teruglevering aan het net is verboden), wordt het PV-vermogen eerst gebruikt om lokale belastingen te voorzien en kan het restant door de omvormer worden beperkt, waardoor de energieopbrengst daalt.</mrk></target><sdl:seg-defs><sdl:seg id="8"><sdl:value key="SegmentIdentityHash">eInmKtFrFAEPNCrvTyEuc0Sa91s=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="a10b8180-9738-430e-b802-f86848a8d156"><source>Environmental and equipment factors</source><seg-source><mrk mtype="seg" mid="9">Environmental and equipment factors</mrk></seg-source><target><mrk mtype="seg" mid="9">Omgevings- en apparatuurfactoren</mrk></target><sdl:seg-defs><sdl:seg id="9"><sdl:value key="SegmentIdentityHash">yTyjp/BT9sMKquMTgtWYyipCaIw=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="d063fb68-f4e5-4203-a3dd-0fae91048073"><source><g id="9">Irradiance fluctuation</g>:</source><seg-source><mrk mtype="seg" mid="10"><g id="9">Irradiance fluctuation</g>:</mrk></seg-source><target><mrk mtype="seg" mid="10"><g id="9">Schommeling van zonnestraling</g>:</mrk></target><sdl:seg-defs><sdl:seg id="10"><sdl:value key="SegmentIdentityHash">8fg8uKDpw+bvPthI8v/lZBKYWcs=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="5a1c83cd-5c56-4ceb-bd4e-20d6552621a9"><source>Momentary cloud shading or weather changes at noon may cause irradiance fluctuations and unstable PV current output (for example, a sudden change in irradiance at constant voltage causes a drop in current).</source><seg-source><mrk mtype="seg" mid="11">Momentary cloud shading or weather changes at noon may cause irradiance fluctuations and unstable PV current output (for example, a sudden change in irradiance at constant voltage causes a drop in current).</mrk></seg-source><target><mrk mtype="seg" mid="11">Kortstondige schaduwwerking door wolken of weersveranderingen rond het middaguur kunnen schommelingen in de zonnestraling veroorzaken en instabiele PV-stroomopbrengst (bijvoorbeeld een plotselinge verandering in de zonnestraling bij constante spanning veroorzaakt een daling van de stroom).</mrk></target><sdl:seg-defs><sdl:seg id="11"><sdl:value key="SegmentIdentityHash">aJCd8vKlG3DrKqmOOa3uKPTeNiM=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="70d92394-3e1d-4a1b-8889-05df94768244"><source>Environmental shading:</source><seg-source><mrk mtype="seg" mid="12">Environmental shading:</mrk></seg-source><target><mrk mtype="seg" mid="12">Omgevingsschaduw:</mrk></target><sdl:seg-defs><sdl:seg id="12"><sdl:value key="SegmentIdentityHash">oucFyMNs8gfmptQn7ys0dSdiiGE=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="a279dfdd-4bd8-4d53-95f8-aa6f4757fce6"><source>PV modules are shaded by trees, building shadows, or dust accumulation, reducing the photoelectric conversion efficiency.</source><seg-source><mrk mtype="seg" mid="13">PV modules are shaded by trees, building shadows, or dust accumulation, reducing the photoelectric conversion efficiency.</mrk></seg-source><target><mrk mtype="seg" mid="13">PV-modules worden beschaduwd door bomen, schaduw van gebouwen of stofafzetting, wat de foto-elektrische omzettingsefficiëntie vermindert.</mrk></target><sdl:seg-defs><sdl:seg id="13"><sdl:value key="SegmentIdentityHash">eUXx4K9LO0ZHd9n2Vd33aPBzof8=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="87554749-1a64-4bea-9736-04c00d1aa219"><source><g id="12">Temperature impact</g>:</source><seg-source><mrk mtype="seg" mid="14"><g id="12">Temperature impact</g>:</mrk></seg-source><target><mrk mtype="seg" mid="14"><g id="12">Temperatuurinvloed</g>:</mrk></target><sdl:seg-defs><sdl:seg id="14"><sdl:value key="SegmentIdentityHash">j5FuWn6r0sYTckDEerR4fnjMyiU=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="7bfe9503-5212-406e-a190-dc494156787d"><source>High temperatures at noon may reduce PV module efficiency, further affecting the actual energy yield.</source><seg-source><mrk mtype="seg" mid="15">High temperatures at noon may reduce PV module efficiency, further affecting the actual energy yield.</mrk></seg-source><target><mrk mtype="seg" mid="15">Hoge temperaturen rond het middaguur kunnen de efficiëntie van PV-modules verminderen, wat de werkelijke energieopbrengst verder beïnvloedt.</mrk></target><sdl:seg-defs><sdl:seg id="15"><sdl:value key="SegmentIdentityHash">rbGWgo7PiwDAtWRsXabk4h2r1gU=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="2c0f9703-86d7-45a2-9bc3-6ec9679eea8b"><source>Abnormal system status:</source><seg-source><mrk mtype="seg" mid="16">Abnormal system status:</mrk></seg-source><target><mrk mtype="seg" mid="16">Systeemstatus</mrk></target><sdl:seg-defs><sdl:seg id="16"><sdl:value key="SegmentIdentityHash">kR1mqOINJ0clq8yI9EdM6vLbFQk=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="3227a172-419d-4b6b-9400-6bdbb1bd3c6f"><source>The inverter has unhandled alarms (such as alarms related to overtemperature and PV module faults) that affect power generation capacity.</source><seg-source><mrk mtype="seg" mid="17">The inverter has unhandled alarms (such as alarms related to overtemperature and PV module faults) that affect power generation capacity.</mrk></seg-source><target><mrk mtype="seg" mid="17">De omvormer heeft onopgeloste alarmen (zoals alarmen met betrekking tot overtemperatuur en PV-modulestoringen) die de opwekcapaciteit beïnvloeden.</mrk></target><sdl:seg-defs><sdl:seg id="17"><sdl:value key="SegmentIdentityHash">2JeoCA2R0i9fMx5bI6Q2ao/T2hM=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="9be9dca8-6a3e-49fd-8b91-ada0261125a0"><source>Intelligent scheduling policy</source><seg-source><mrk mtype="seg" mid="18">Intelligent scheduling policy</mrk></seg-source><target><mrk mtype="seg" mid="18" /></target><sdl:seg-defs><sdl:seg id="18" locked="true"><sdl:rep id="W+DLwk9wMfyNoG/kiyT7ETOya9g=" /><sdl:value key="SegmentIdentityHash">W+DLwk9wMfyNoG/kiyT7ETOya9g=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="f02ff66c-62cc-43df-8b5d-a8743ac22400"><source>The <x id="13" /> may prioritize feeding PV power directly into the grid during high electricity price periods at noon based on the time-of-use electricity price policy, rather than using all of it for power generation (if the returns from selling electricity are higher).</source><seg-source><mrk mtype="seg" mid="19">The <x id="13" /> may prioritize feeding PV power directly into the grid during high electricity price periods at noon based on the time-of-use electricity price policy, rather than using all of it for power generation (if the returns from selling electricity are higher).</mrk></seg-source><target><mrk mtype="seg" mid="19">De <x id="13" /> kan prioriteit geven aan het direct terugleveren van PV-vermogen aan het net tijdens periodes met hoge elektriciteitsprijzen rond het middaguur, op basis van het tijdsafhankelijke elektriciteitsprijsbeleid, in plaats van dit geheel te gebruiken voor energieopwekking (als de opbrengsten uit de verkoop van elektriciteit hoger zijn).</mrk></target><sdl:seg-defs><sdl:seg id="19"><sdl:value key="SegmentIdentityHash">vwWIVr7OucqwHpcLOYQqpViyWAM=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group></body></file></xliff>