nt</value><value key="displayText">&lt;uicontrol class="+ topic/ph ui-d/uicontrol " id="uicontrol18815162434613" conref="en-us_topic_0000207784935935.xml#460689" idp:conrefpath="200650494000#EN-US_BOOKMAP_0000002298267098#EN-US_TOPIC_0000207784935935"/&gt;</value><value key="hasDisplayText">True</value><value key="attribute:id">f0</value></props></tag><tag id="11"><ph name="&lt;ph class=&quot;- topic/ph &quot; conref=&quot;en-us_topic_0000001645659009.xml#ph122067484595&quot; id=&quot;ph15116442102016&quot; idp:conrefpath=&quot;200650494000#EN-US_BOOKMAP_0000001596019118#EN-US_TOPIC_0000001645659009&quot; idp:userph=&quot;true&quot;/&gt;" word-end="false">&lt;ph id="f0"&gt;</ph><props><value key="prefix"></value><value key="localName">ph</value><value key="namespaces"></value><value key="isEmptyElement">False</value><value key="nodeType">Element</value><value key="displayText">&lt;ph class="- topic/ph " conref="en-us_topic_0000001645659009.xml#ph122067484595" id="ph15116442102016" idp:conrefpath="200650494000#EN-US_BOOKMAP_0000001596019118#EN-US_TOPIC_0000001645659009" idp:userph="true"/&gt;</value><value key="hasDisplayText">True</value><value key="attribute:id">f0</value></props></tag></tag-defs></header><body><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="f2493366-ee44-4462-ab1b-46b1ded3c537"><source>Why Is the Battery Power Not Used Up on the Same Day?</source><seg-source><mrk mtype="seg" mid="1">Why Is the Battery Power Not Used Up on the Same Day?</mrk></seg-source><target><mrk mtype="seg" mid="1">Why Is the Battery Power Not Used Up on the Same Day?</mrk></target><sdl:seg-defs><sdl:seg id="1" origin="source"><sdl:value key="SegmentIdentityHash">MlQ7DrbuOzO+0NIZsmjNYrkyTdI=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="a4bc4e47-194c-420b-9ceb-078d56c1a2ad"><source>Cross-period economic optimization</source><seg-source><mrk mtype="seg" mid="2">Cross-period economic optimization</mrk></seg-source><target><mrk mtype="seg" mid="2">Cross-period economic optimization</mrk></target><sdl:seg-defs><sdl:seg id="2" origin="source"><sdl:value key="SegmentIdentityHash">xT3Q5lggbrtbdgD9sO0dIKv5QY8=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="3801423a-4512-41fb-9dff-e7a6a506b7d1"><source>The <x id="0" /> dynamically schedules battery charge and discharge based on AI algorithms that forecast load, PV output, and electricity prices.</source><seg-source><mrk mtype="seg" mid="3">The <x id="0" /> dynamically schedules battery charge and discharge based on AI algorithms that forecast load, PV output, and electricity prices.</mrk></seg-source><target><mrk mtype="seg" mid="3">The <x id="0" /> dynamically schedules battery charge and discharge based on AI algorithms that forecast load, PV output, and electricity prices.</mrk></target><sdl:seg-defs><sdl:seg id="3" origin="source"><sdl:value key="SegmentIdentityHash">1CUN/fSPIK0Fue7ljtxEgIhTtOA=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="9c78a7f5-4085-471b-8e7f-2b6b3d48f5ad"><source>The system reserves some energy for discharge during <g id="3">periods with higher electricity prices on the next day</g> to maximize the returns from energy arbitrage.</source><seg-source><mrk mtype="seg" mid="4">The system reserves some energy for discharge during <g id="3">periods with higher electricity prices on the next day</g> to maximize the returns from energy arbitrage.</mrk></seg-source><target><mrk mtype="seg" mid="4">The system reserves some energy for discharge during <g id="3">periods with higher electricity prices on the next day</g> to maximize the returns from energy arbitrage.</mrk></target><sdl:seg-defs><sdl:seg id="4" origin="source"><sdl:value key="SegmentIdentityHash">NKOh62wj+tdpbZ3ySbUacARyjhU=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="603a86d5-3167-4bb6-9d5b-93788feedcc4"><source>If the battery is fully discharged on the current day, better arbitrage opportunities on the next day may be missed.</source><seg-source><mrk mtype="seg" mid="5">If the battery is fully discharged on the current day, better arbitrage opportunities on the next day may be missed.</mrk></seg-source><target><mrk mtype="seg" mid="5">If the battery is fully discharged on the current day, better arbitrage opportunities on the next day may be missed.</mrk></target><sdl:seg-defs><sdl:seg id="5" origin="source"><sdl:value key="SegmentIdentityHash">g6GOPdNBcQRs7aVtS7C+310Xt94=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="d4dfbf66-1c76-4745-ae77-a12ebadeee43"><source>Active response to negative electricity prices</source><seg-source><mrk mtype="seg" mid="6">Active response to negative electricity prices</mrk></seg-source><target><mrk mtype="seg" mid="6">Active response to negative electricity prices</mrk></target><sdl:seg-defs><sdl:seg id="6" origin="source"><sdl:value key="SegmentIdentityHash">A6vY5dgma79nthpI6GNNzSuQj38=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="d2e78c91-9d09-4f18-bd7e-08639fb1bba5"><source><g id="6">Charging first</g>:</source><seg-source><mrk mtype="seg" mid="7"><g id="6">Charging first</g>:</mrk></seg-source><target><mrk mtype="seg" mid="7"><g id="6">Charging first</g>:</mrk></target><sdl:seg-defs><sdl:seg id="7" origin="source"><sdl:value key="SegmentIdentityHash">aiGxvTenwYEVKkv0fcEDWx5f8AQ=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="9f5700cd-f520-41f4-9be5-fc10d600d43f"><source>When the electricity price is negative (the purchase price is negative), the system preferentially purchases electricity from the grid for charging.</source><seg-source><mrk mtype="seg" mid="8">When the electricity price is negative (the purchase price is negative), the system preferentially purchases electricity from the grid for charging.</mrk></seg-source><target><mrk mtype="seg" mid="8">When the electricity price is negative (the purchase price is negative), the system preferentially purchases electricity from the grid for charging.</mrk></target><sdl:seg-defs><sdl:seg id="8" origin="source"><sdl:value key="SegmentIdentityHash">RJNRbnsS6NWTEhO5OP7Zl+GmV/w=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="d9214e52-4517-422d-aed4-96fecfd64ca6"><source>In this case, the battery may be in the charging state instead of the discharging state.</source><seg-source><mrk mtype="seg" mid="9">In this case, the battery may be in the charging state instead of the discharging state.</mrk></seg-source><target><mrk mtype="seg" mid="9">In this case, the battery may be in the charging state instead of the discharging state.</mrk></target><sdl:seg-defs><sdl:seg id="9" origin="source"><sdl:value key="SegmentIdentityHash">eVU9HRTu6n5xguvgZ9X2vQGhLdo=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="712afe84-c865-4c8a-a9b6-ebf447a7cc29"><source><g id="9">Policy adjustment</g>:</source><seg-source><mrk mtype="seg" mid="10"><g id="9">Policy adjustment</g>:</mrk></seg-source><target><mrk mtype="seg" mid="10"><g id="9">Policy adjustment</g>:</mrk></target><sdl:seg-defs><sdl:seg id="10" origin="source"><sdl:value key="SegmentIdentityHash">Kxx6at/tdierTX7MElEp/P1IPzc=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="83234ad7-46dd-448f-a75e-110ed2383932"><source>After the negative rate optimization function is enabled, the battery proactively charges during low electricity price periods (including negative electricity prices) to reduce the discharge amount.</source><seg-source><mrk mtype="seg" mid="11">After the negative rate optimization function is enabled, the battery proactively charges during low electricity price periods (including negative electricity prices) to reduce the discharge amount.</mrk></seg-source><target><mrk mtype="seg" mid="11">After the negative rate optimization function is enabled, the battery proactively charges during low electricity price periods (including negative electricity prices) to reduce the discharge amount.</mrk></target><sdl:seg-defs><sdl:seg id="11" origin="source"><sdl:value key="SegmentIdentityHash">FqpR+ZWz0PDOq5VAgLg/MGhRqHs=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="d9bfed31-4ca0-4930-9adb-d43399763c1d"><source>SOC protection and backup power requirements</source><seg-source><mrk mtype="seg" mid="12">SOC protection and backup power requirements</mrk></seg-source><target><mrk mtype="seg" mid="12">SOC protection and backup power requirements</mrk></target><sdl:seg-defs><sdl:seg id="12" origin="source"><sdl:value key="SegmentIdentityHash">rsLSYZXQqYTo0JyQ97GK9lS2lxg=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="4e450889-ff75-437f-9fd3-fa3191fbe1f1"><source>The system sets the end-of-discharge SOC (for example, 50%) to prevent overdischarge and battery damage, and reserves <x id="10" /> to cope with unexpected power outages.</source><seg-source><mrk mtype="seg" mid="13">The system sets the end-of-discharge SOC (for example, 50%) to prevent overdischarge and battery damage, and reserves <x id="10" /> to cope with unexpected power outages.</mrk></seg-source><target><mrk mtype="seg" mid="13">The system sets the end-of-discharge SOC (for example, 50%) to prevent overdischarge and battery damage, and reserves <x id="10" /> to cope with unexpected power outages.</mrk></target><sdl:seg-defs><sdl:seg id="13" origin="source"><sdl:value key="SegmentIdentityHash">iEmHsbQ3kSi4j3TNjJq6f5dtbtM=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="d5ce80a7-bbd2-4c8c-b033-6416f1a133fe"><source>The <x id="11" /> dynamically adjusts the discharge threshold based on the power backup requirements.</source><seg-source><mrk mtype="seg" mid="14">The <x id="11" /> dynamically adjusts the discharge threshold based on the power backup requirements.</mrk></seg-source><target><mrk mtype="seg" mid="14">The <x id="11" /> dynamically adjusts the discharge threshold based on the power backup requirements.</mrk></target><sdl:seg-defs><sdl:seg id="14" origin="source"><sdl:value key="SegmentIdentityHash">kvuvHzJBSTLwThf/6oIUg4tjltE=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="9c5a982b-5b13-48fc-a55d-1d7b95b48f1a"><source>Power and load matching</source><seg-source><mrk mtype="seg" mid="15">Power and load matching</mrk></seg-source><target><mrk mtype="seg" mid="15">Power and load matching</mrk></target><sdl:seg-defs><sdl:seg id="15" origin="source"><sdl:value key="SegmentIdentityHash">bpETb46Ob+vbwrDi8h4rShnLqPY=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="2625c1b1-f998-42a4-9752-bc89d2724ee4"><source>If the load demand is lower than the battery's discharge power, the system adjusts the discharge output accordingly to avoid energy waste.</source><seg-source><mrk mtype="seg" mid="16">If the load demand is lower than the battery's discharge power, the system adjusts the discharge output accordingly to avoid energy waste.</mrk></seg-source><target><mrk mtype="seg" mid="16">If the load demand is lower than the battery's discharge power, the system adjusts the discharge output accordingly to avoid energy waste.</mrk></target><sdl:seg-defs><sdl:seg id="16" origin="source"><sdl:value key="SegmentIdentityHash">s4WM9mDpnJKzA0Exn/MTAQJg7pY=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="111e21a4-3c49-4844-afb4-3d1eb7da0bec"><source>For example, during light-load periods, the battery supplies only part of the power, with the remaining charge reserved for future use.</source><seg-source><mrk mtype="seg" mid="17">For example, during light-load periods, the battery supplies only part of the power, with the remaining charge reserved for future use.</mrk></seg-source><target><mrk mtype="seg" mid="17">For example, during light-load periods, the battery supplies only part of the power, with the remaining charge reserved for future use.</mrk></target><sdl:seg-defs><sdl:seg id="17" origin="source"><sdl:value key="SegmentIdentityHash">QvZkdAdW5vquTH7QIUCuPTAjEZI=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group></body></file></xliff>