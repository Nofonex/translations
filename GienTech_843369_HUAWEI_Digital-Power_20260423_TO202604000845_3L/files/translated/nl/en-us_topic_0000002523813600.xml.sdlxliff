298266790#EN-US_TOPIC_0000207784470567&quot;/&gt;" word-end="false">&lt;ph id="f0"&gt;</ph><props><value key="prefix"></value><value key="localName">ph</value><value key="namespaces"></value><value key="isEmptyElement">False</value><value key="nodeType">Element</value><value key="displayText">&lt;uicontrol class="+ topic/ph ui-d/uicontrol " id="uicontrol1891019245456" conref="en-us_topic_0000207784470567.xml#438333" idp:conrefpath="200650494000#EN-US_BOOKMAP_0000002298266790#EN-US_TOPIC_0000207784470567"/&gt;</value><value key="hasDisplayText">True</value><value key="attribute:id">f0</value></props></tag><tag id="1"><ph name="&lt;uicontrol class=&quot;+ topic/ph ui-d/uicontrol &quot; id=&quot;uicontrol55241626133415&quot; conref=&quot;en-us_topic_0000207635068172.xml#456541&quot; idp:conrefpath=&quot;200650494000#EN-US_BOOKMAP_0000002298267098#EN-US_TOPIC_0000207635068172&quot;/&gt;" word-end="false">&lt;ph id="f1"&gt;</ph><props><value key="prefix"></value><value key="localName">ph</value><value key="namespaces"></value><value key="isEmptyElement">False</value><value key="nodeType">Element</value><value key="displayText">&lt;uicontrol class="+ topic/ph ui-d/uicontrol " id="uicontrol55241626133415" conref="en-us_topic_0000207635068172.xml#456541" idp:conrefpath="200650494000#EN-US_BOOKMAP_0000002298267098#EN-US_TOPIC_0000207635068172"/&gt;</value><value key="hasDisplayText">True</value><value key="attribute:id">f1</value></props></tag><tag id="8"><ph name="&lt;ph class=&quot;- topic/ph &quot; conref=&quot;en-us_topic_0000001645659009.xml#ph122067484595&quot; id=&quot;ph1959151418587&quot; idp:conrefpath=&quot;200650494000#EN-US_BOOKMAP_0000001596019118#EN-US_TOPIC_0000001645659009&quot; idp:userph=&quot;true&quot;/&gt;" word-end="false">&lt;ph id="f0"&gt;</ph><props><value key="prefix"></value><value key="localName">ph</value><value key="namespaces"></value><value key="isEmptyElement">False</value><value key="nodeType">Element</value><value key="displayText">&lt;ph class="- topic/ph " conref="en-us_topic_0000001645659009.xml#ph122067484595" id="ph1959151418587" idp:conrefpath="200650494000#EN-US_BOOKMAP_0000001596019118#EN-US_TOPIC_0000001645659009" idp:userph="true"/&gt;</value><value key="hasDisplayText">True</value><value key="attribute:id">f0</value></props></tag></tag-defs></header><body><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="bf818b0b-58cf-46d7-8e2a-72393aae097a"><source>Why Is PV Power Not Used to Charge the Battery?</source><seg-source><mrk mtype="seg" mid="1">Why Is PV Power Not Used to Charge the Battery?</mrk></seg-source><target><mrk mtype="seg" mid="1">Waarom wordt PV-vermogen niet gebruikt om de batterij op te laden?</mrk></target><sdl:seg-defs><sdl:seg id="1"><sdl:value key="SegmentIdentityHash">5GRmFpC2eoV5qxnU9dCFqVZXoWw=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="5029e95c-fb33-4c0f-a6a3-649d8d54d5fa"><source>Economic returns first</source><seg-source><mrk mtype="seg" mid="2">Economic returns first</mrk></seg-source><target><mrk mtype="seg" mid="2">Economische opbrengsten eerst</mrk></target><sdl:seg-defs><sdl:seg id="2"><sdl:value key="SegmentIdentityHash">OKycZxZ7gWAbnbOzBCvrCzyKIM8=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="1856e421-80f3-4c20-9251-5e0798133203"><source>When PV power is generated, if the feed-in electricity price (peak feed-in electricity price) is higher than or close to the net returns from charging and then discharging the battery, the system will prioritize selling the PV power directly to the grid.</source><seg-source><mrk mtype="seg" mid="3">When PV power is generated, if the feed-in electricity price (peak feed-in electricity price) is higher than or close to the net returns from charging and then discharging the battery, the system will prioritize selling the PV power directly to the grid.</mrk></seg-source><target><mrk mtype="seg" mid="3">Wanneer er PV-vermogen wordt opgewekt en de terugleveringsprijs van elektriciteit (piek-terugleveringsprijs) hoger is dan of dicht in de buurt komt van de netto-opbrengst van het opladen en vervolgens ontladen van de batterij, zal het systeem prioriteit geven aan het rechtstreeks verkopen van het PV-vermogen aan het net.</mrk></target><sdl:seg-defs><sdl:seg id="3"><sdl:value key="SegmentIdentityHash">JhBNiMn79zWo6pRUHPtb4D7Ak4s=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="ff88e840-16da-4059-8722-6b45e77f7b9d"><source><x id="0" /> charging window and <x id="1" /> mode restrictions</source><seg-source><x id="0" /> <mrk mtype="seg" mid="4">charging window and <x id="1" /> mode restrictions</mrk></seg-source><target><x id="0" /> <mrk mtype="seg" mid="4">beperkingen voor laadvenster en modus <x id="1" /></mrk></target><sdl:seg-defs><sdl:seg id="4"><sdl:value key="SegmentIdentityHash">OWYtMVMgDLxWwLnozcqbY630lU4=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="25a6a23d-37df-4973-a8c6-9d08d154b2fb"><source>If the charging window does not cover the PV generation period (for example, the PV peak is at noon but the charging window is set in the early morning), the PV power is used first to meet home load demand, with the remainder sold directly to the grid rather than stored.</source><seg-source><mrk mtype="seg" mid="5">If the charging window does not cover the PV generation period (for example, the PV peak is at noon but the charging window is set in the early morning), the PV power is used first to meet home load demand, with the remainder sold directly to the grid rather than stored.</mrk></seg-source><target><mrk mtype="seg" mid="5">Als het laadvenster de PV-opwekkingsperiode niet dekt (bijvoorbeeld de PV-piek ligt rond het middaguur, maar het laadvenster is ingesteld in de vroege ochtend), wordt het PV-vermogen eerst gebruikt om aan de belastingsvraag van de woning te voldoen, waarbij het restant rechtstreeks aan het net wordt verkocht in plaats van opgeslagen.</mrk></target><sdl:seg-defs><sdl:seg id="5"><sdl:value key="SegmentIdentityHash">6ghy+KsO8w88GzU50AmWsjdoZV8=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="1e0d528c-03ac-44ac-9e78-f1b2c3c5ee8f"><source>System status and forecast</source><seg-source><mrk mtype="seg" mid="6">System status and forecast</mrk></seg-source><target><mrk mtype="seg" mid="6">Systeemstatus en voorspelling</mrk></target><sdl:seg-defs><sdl:seg id="6"><sdl:value key="SegmentIdentityHash">JJkh8rDr8zZGCdRK0EkVReeYW1o=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="86db5d2d-05b5-4fd8-ae4d-258696079f0a"><source><g id="4">High SOC</g>:</source><seg-source><mrk mtype="seg" mid="7"><g id="4">High SOC</g>:</mrk></seg-source><target><mrk mtype="seg" mid="7"><g id="4">Hoge SOC</g>:</mrk></target><sdl:seg-defs><sdl:seg id="7"><sdl:value key="SegmentIdentityHash">zUPsWTxHS1qsdn9J3SUDcuJu0gY=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="86355de1-b78b-4129-850c-7d729a0f2205"><source>If the SOC has reached the preset end-of-charge threshold (for example, 90%), the system stops charging to prevent overcharging.</source><seg-source><mrk mtype="seg" mid="8">If the SOC has reached the preset end-of-charge threshold (for example, 90%), the system stops charging to prevent overcharging.</mrk></seg-source><target><mrk mtype="seg" mid="8">Als de SOC de vooraf ingestelde drempelwaarde voor einde opladen heeft bereikt (bijvoorbeeld 90%), stopt het systeem met opladen om overladen te voorkomen.</mrk></target><sdl:seg-defs><sdl:seg id="8"><sdl:rep id="Q3HWpD0GGpivJqmPvp2p0pCC7EM=" /><sdl:value key="SegmentIdentityHash">Q3HWpD0GGpivJqmPvp2p0pCC7EM=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="5861059e-0ab0-40d7-91d8-5118b4a950cd"><source>In this case, the PV power is fed to the grid or supplied to loads.</source><seg-source><mrk mtype="seg" mid="9">In this case, the PV power is fed to the grid or supplied to loads.</mrk></seg-source><target><mrk mtype="seg" mid="9">In dat geval wordt het PV-vermogen aan het net teruggeleverd of aan belastingen geleverd.</mrk></target><sdl:seg-defs><sdl:seg id="9"><sdl:rep id="6hLitGY/pPQz2u+G0N/VehLhk6E=" /><sdl:value key="SegmentIdentityHash">6hLitGY/pPQz2u+G0N/VehLhk6E=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="8ab7eaa1-0bec-4dc6-ba54-213db63e4699"><source><g id="7">Intelligent scheduling policy</g>:</source><seg-source><mrk mtype="seg" mid="10"><g id="7">Intelligent scheduling policy</g>:</mrk></seg-source><target><mrk mtype="seg" mid="10">Intelligente [planning]</mrk></target><sdl:seg-defs><sdl:seg id="10"><sdl:rep id="XCXeUaRyPRDP8BL7JAHazNP/sdE=" /><sdl:value key="SegmentIdentityHash">XCXeUaRyPRDP8BL7JAHazNP/sdE=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="56f86219-42c9-4bdc-a1ec-c8ed5de45de8"><source>The <x id="8" /> forecasts the future electricity prices and load.</source><seg-source><mrk mtype="seg" mid="11">The <x id="8" /> forecasts the future electricity prices and load.</mrk></seg-source><target><mrk mtype="seg" mid="11">De <x id="8" /> voorspelt de toekomstige elektriciteitsprijzen en belasting.</mrk></target><sdl:seg-defs><sdl:seg id="11"><sdl:value key="SegmentIdentityHash">54Pp01UXUYr8YDhNGU9lv9JBLEs=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="43e4e236-7bae-4bb9-b370-21492a967f7b"><source>If the system forecasts that electricity prices will be lower or PV output will be more abundant later, it may delay charging and wait for a better opportunity.</source><seg-source><mrk mtype="seg" mid="12">If the system forecasts that electricity prices will be lower or PV output will be more abundant later, it may delay charging and wait for a better opportunity.</mrk></seg-source><target><mrk mtype="seg" mid="12">Als het systeem voorspelt dat de elektriciteitsprijzen later lager zullen zijn of dat de PV-opbrengst overvloediger zal zijn, kan het opladen worden uitgesteld en op een beter moment worden gewacht.</mrk></target><sdl:seg-defs><sdl:seg id="12"><sdl:value key="SegmentIdentityHash">1F9c5wGjgSpiE11FoByVHaeSELw=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group></body></file></xliff>