uot; idp:userph=&quot;true&quot;/&gt;" word-end="false">&lt;ph id="f0"&gt;</ph><props><value key="prefix"></value><value key="localName">ph</value><value key="namespaces"></value><value key="isEmptyElement">False</value><value key="nodeType">Element</value><value key="displayText">&lt;ph class="- topic/ph " conref="en-us_topic_0000001645659009.xml#ph122067484595" id="ph1959151418587" idp:conrefpath="200650494000#EN-US_BOOKMAP_0000001596019118#EN-US_TOPIC_0000001645659009" idp:userph="true"/&gt;</value><value key="hasDisplayText">True</value><value key="attribute:id">f0</value></props></tag></tag-defs></header><body><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="e61dc2e8-3579-4136-92fc-752db336104a"><source>Why Is the Battery Not Fully Charged When the Electricity Price Is Low?</source><seg-source><mrk mtype="seg" mid="1">Why Is the Battery Not Fully Charged When the Electricity Price Is Low?</mrk></seg-source><target><mrk mtype="seg" mid="1">Waarom wordt de batterij niet volledig opgeladen wanneer de elektriciteitsprijs laag is?</mrk></target><sdl:seg-defs><sdl:seg id="1"><sdl:value key="SegmentIdentityHash">GTQMRCNIuw2oyLZDCiSqMSzmbzc=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="978a393b-dcd4-4145-8416-646a25d3850d"><source>Operating mode restrictions</source><seg-source><mrk mtype="seg" mid="2">Operating mode restrictions</mrk></seg-source><target><mrk mtype="seg" mid="2" /></target><sdl:seg-defs><sdl:seg id="2" locked="true"><sdl:rep id="Yc18EA/Q9GEJRpzkJlatR+uRjJA=" /><sdl:value key="SegmentIdentityHash">Yc18EA/Q9GEJRpzkJlatR+uRjJA=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="9f876e44-9804-443c-97c1-0799bb081c7b"><source><g id="3"><x id="1" /></g>:</source><seg-source><g id="3"><x id="1" /></g><mrk mtype="seg" mid="3">:</mrk></seg-source><target><g id="3"><x id="1" /></g><mrk mtype="seg" mid="3">:</mrk></target><sdl:seg-defs><sdl:seg id="3"><sdl:value key="SegmentIdentityHash">uTb47TYidzYIYg8NV8ThUeDuO9s=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="0c2cec45-e32f-4c99-9b8b-6281bbbcc21a"><source>If this mode is selected, the system allows only surplus PV power to charge the battery and prohibits charging from the grid.</source><seg-source><mrk mtype="seg" mid="4">If this mode is selected, the system allows only surplus PV power to charge the battery and prohibits charging from the grid.</mrk></seg-source><target><mrk mtype="seg" mid="4">Als deze modus is geselecteerd, staat het systeem alleen toe dat overtollig PV-vermogen de batterij oplaadt en verbiedt het opladen vanaf het net.</mrk></target><sdl:seg-defs><sdl:seg id="4"><sdl:value key="SegmentIdentityHash">kWUdbkM/m457zbTSzzfZmuj3SlM=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="55736d78-fb2b-4856-8936-c03bbf5511ae"><source>Therefore, the battery cannot obtain power from the grid even during low electricity price periods.</source><seg-source><mrk mtype="seg" mid="5">Therefore, the battery cannot obtain power from the grid even during low electricity price periods.</mrk></seg-source><target><mrk mtype="seg" mid="5">Daardoor kan de batterij geen stroom van het net verkrijgen, zelfs niet tijdens periodes met lage elektriciteitsprijzen.</mrk></target><sdl:seg-defs><sdl:seg id="5"><sdl:value key="SegmentIdentityHash">Rdsqoe/h/UEUoYRxTFkR0VJa0tk=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="b7ac98cf-469a-4a7f-808b-1bfbd9dc43c8"><source><g id="7"><x id="5" /></g>:</source><seg-source><mrk mtype="seg" mid="6"><g id="7"><x id="5" /></g>:</mrk></seg-source><target><mrk mtype="seg" mid="6" /></target><sdl:seg-defs><sdl:seg id="6" locked="true"><sdl:value key="SegmentIdentityHash">va9whzuSIXAQ+74S28LpO38Kcec=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="01c5091b-2575-446b-a3ed-e9d09bf7c57b"><source>In this mode, you need to manually set the low electricity price period as the charging period.</source><seg-source><mrk mtype="seg" mid="7">In this mode, you need to manually set the low electricity price period as the charging period.</mrk></seg-source><target><mrk mtype="seg" mid="7">In deze modus moet u de periode met lage elektriciteitsprijzen handmatig instellen als oplaadperiode.</mrk></target><sdl:seg-defs><sdl:seg id="7"><sdl:value key="SegmentIdentityHash">GKM6Qf+7MJqrEJq8/tIgFl0iwuo=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="07bdaaa3-61fe-4a30-acbf-8f30bb4071a4"><source>If the period is incorrectly set, the charging function will fail.</source><seg-source><mrk mtype="seg" mid="8">If the period is incorrectly set, the charging function will fail.</mrk></seg-source><target><mrk mtype="seg" mid="8">Als de periode onjuist is ingesteld, werkt de oplaadfunctie niet.</mrk></target><sdl:seg-defs><sdl:seg id="8"><sdl:value key="SegmentIdentityHash">Fwtx7+rNM9nEpwKxkAioZLtvBok=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="299e1d54-2034-4398-91c6-458e2d2f2a0a"><source>If the corresponding time period is not added or the time period is incorrectly set, the system cannot perform charging during low electricity price periods.</source><seg-source><mrk mtype="seg" mid="9">If the corresponding time period is not added or the time period is incorrectly set, the system cannot perform charging during low electricity price periods.</mrk></seg-source><target><mrk mtype="seg" mid="9">Als de overeenkomstige tijdsperiode niet is toegevoegd of de tijdsperiode onjuist is ingesteld, kan het systeem niet opladen tijdens periodes met lage elektriciteitsprijzen.</mrk></target><sdl:seg-defs><sdl:seg id="9"><sdl:value key="SegmentIdentityHash">8vHLQFtKdHjWXJrbcj7xDOFAyY8=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="00b25431-67f7-4210-b89d-643739479d20"><source>Function switch status</source><seg-source><mrk mtype="seg" mid="10">Function switch status</mrk></seg-source><target><mrk mtype="seg" mid="10" /></target><sdl:seg-defs><sdl:seg id="10" locked="true"><sdl:rep id="tl9kB4a1a43HGsqWwhwgeY+n/jI=" /><sdl:value key="SegmentIdentityHash">tl9kB4a1a43HGsqWwhwgeY+n/jI=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="870d5901-adf1-4530-a4a0-565408ff65e1"><source><g id="10">Grid charging not enabled</g>:</source><seg-source><mrk mtype="seg" mid="11"><g id="10">Grid charging not enabled</g>:</mrk></seg-source><target><mrk mtype="seg" mid="11"><g id="10">Opladen vanaf het net niet ingeschakeld</g>:</mrk></target><sdl:seg-defs><sdl:seg id="11"><sdl:value key="SegmentIdentityHash">q5a6wjsfC6/SBeIJ0ecX05NXzAU=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="83041aff-96a2-4a2b-aa55-8606cf5830f6"><source>The <x id="11" /> function is disabled by default.</source><seg-source><mrk mtype="seg" mid="12">The <x id="11" /> function is disabled by default.</mrk></seg-source><target><mrk mtype="seg" mid="12" /></target><sdl:seg-defs><sdl:seg id="12" locked="true"><sdl:rep id="QK03W2M+OakGcLHMaMZHnrKnpiY=" /><sdl:value key="SegmentIdentityHash">QK03W2M+OakGcLHMaMZHnrKnpiY=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="5a660c62-2ac1-4513-8f92-8b0202149ba2"><source>You need to manually enable it to charge the battery at a low electricity price.</source><seg-source><mrk mtype="seg" mid="13">You need to manually enable it to charge the battery at a low electricity price.</mrk></seg-source><target><mrk mtype="seg" mid="13" /></target><sdl:seg-defs><sdl:seg id="13" locked="true"><sdl:rep id="gRBVB9RLSXw3I+8GkKAW7IuMra4=" /><sdl:value key="SegmentIdentityHash">gRBVB9RLSXw3I+8GkKAW7IuMra4=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="140c59e8-81da-43fb-a9f1-fc3837f1dfe1"><source>System parameter settings</source><seg-source><mrk mtype="seg" mid="14">System parameter settings</mrk></seg-source><target><mrk mtype="seg" mid="14" /></target><sdl:seg-defs><sdl:seg id="14" locked="true"><sdl:rep id="xqlVPIqapJSGfXGI+tQZGFBlOMk=" /><sdl:value key="SegmentIdentityHash">xqlVPIqapJSGfXGI+tQZGFBlOMk=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="8c32fbd5-cc85-4f7b-8c2b-f4308ee98904"><source>SOC restrictions</source><seg-source><mrk mtype="seg" mid="15">SOC restrictions</mrk></seg-source><target><mrk mtype="seg" mid="15">SOC-beperkingen</mrk></target><sdl:seg-defs><sdl:seg id="15"><sdl:value key="SegmentIdentityHash">DQ8mtgig7SV0ALjFk9tnVq7vSOQ=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="12691cda-de67-4d90-b5a5-f9aad075d58d"><source>The <x id="12" /> is set too low (for example, 80%).</source><seg-source><mrk mtype="seg" mid="16">The <x id="12" /> is set too low (for example, 80%).</mrk></seg-source><target><mrk mtype="seg" mid="16" /></target><sdl:seg-defs><sdl:seg id="16" locked="true"><sdl:rep id="8XsQkxHsv5W/l3xhWMbpbxO5WaM=" /><sdl:value key="SegmentIdentityHash">8XsQkxHsv5W/l3xhWMbpbxO5WaM=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="4b26de56-4684-4dd8-aab2-394607c03fe2"><source>When the threshold is reached, charging stops.</source><seg-source><mrk mtype="seg" mid="17">When the threshold is reached, charging stops.</mrk></seg-source><target><mrk mtype="seg" mid="17" /></target><sdl:seg-defs><sdl:seg id="17" locked="true"><sdl:rep id="eXu+h3y0ZCdfHQY/NRqfCV4bBAs=" /><sdl:value key="SegmentIdentityHash">eXu+h3y0ZCdfHQY/NRqfCV4bBAs=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="aa572b47-2ccd-4746-a7ea-39279df349d9"><source>Reserve the <x id="13" /> for peak shaving, stopping charging in advance.</source><seg-source><mrk mtype="seg" mid="18">Reserve the <x id="13" /> for peak shaving, stopping charging in advance.</mrk></seg-source><target><mrk mtype="seg" mid="18" /></target><sdl:seg-defs><sdl:seg id="18" locked="true"><sdl:rep id="pFdr6hxDSWuRwB3UAeA4NWoloeI=" /><sdl:value key="SegmentIdentityHash">pFdr6hxDSWuRwB3UAeA4NWoloeI=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="d612c35f-0e32-412f-a225-e1b79c659fa8"><source>Power limit</source><seg-source><mrk mtype="seg" mid="19">Power limit</mrk></seg-source><target><mrk mtype="seg" mid="19" /></target><sdl:seg-defs><sdl:seg id="19" locked="true"><sdl:rep id="iyHtoKziaWifRN0Xoi5XwrmPzX4=" /><sdl:value key="SegmentIdentityHash">iyHtoKziaWifRN0Xoi5XwrmPzX4=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="802bda82-ff93-4969-9fef-94b2c0173444"><source>The <x id="14" /> parameter is set to an excessively low value.</source><seg-source><mrk mtype="seg" mid="20">The <x id="14" /> parameter is set to an excessively low value.</mrk></seg-source><target><mrk mtype="seg" mid="20">De parameter <x id="14" /> is ingesteld op een te lage waarde.</mrk></target><sdl:seg-defs><sdl:seg id="20"><sdl:value key="SegmentIdentityHash">m+b7TjPFGDX/5E1cdOnfKTAZ8CY=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="96d809c0-fa62-4f99-a21a-1c91d18290d6"><source>The <g id="17">Maximum charge power</g> parameter of the battery is set to an excessively low value.</source><seg-source><mrk mtype="seg" mid="21">The <g id="17">Maximum charge power</g> parameter of the battery is set to an excessively low value.</mrk></seg-source><target><mrk mtype="seg" mid="21">De parameter <g id="17">Maximaal oplaadvermogen</g> van de batterij is ingesteld op een te lage waarde.</mrk></target><sdl:seg-defs><sdl:seg id="21"><sdl:value key="SegmentIdentityHash">M2U092dgB06NrPzfTqDn3ZeE84Q=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="e8543a65-1fb2-4666-b5ea-fae2ae96379b"><source>The <x id="18" /> function is also added to limit the maximum power purchased from the grid.</source><seg-source><mrk mtype="seg" mid="22">The <x id="18" /> function is also added to limit the maximum power purchased from the grid.</mrk></seg-source><target><mrk mtype="seg" mid="22">De functie <x id="18" /> is ook toegevoegd om het maximaal vanaf het net ingekochte vermogen te beperken.</mrk></target><sdl:seg-defs><sdl:seg id="22"><sdl:value key="SegmentIdentityHash">1CzDSYVdHo9dhwRjQnS5oP4bwUE=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="8fdab0de-0a7e-4bdf-9683-48d40918ece3"><source>Intelligent scheduling policy</source><seg-source><mrk mtype="seg" mid="23">Intelligent scheduling policy</mrk></seg-source><target><mrk mtype="seg" mid="23" /></target><sdl:seg-defs><sdl:seg id="23" locked="true"><sdl:rep id="W+DLwk9wMfyNoG/kiyT7ETOya9g=" /><sdl:value key="SegmentIdentityHash">W+DLwk9wMfyNoG/kiyT7ETOya9g=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="321ea9fa-5885-42e2-b3ec-fb4e33862ccd"><source><g id="21">Load demand first</g>:</source><seg-source><mrk mtype="seg" mid="24"><g id="21">Load demand first</g>:</mrk></seg-source><target><mrk mtype="seg" mid="24"><g id="21">Belastingsvraag eerst</g>:</mrk></target><sdl:seg-defs><sdl:seg id="24"><sdl:value key="SegmentIdentityHash">5CRz3/7Q9LMHJdGYWpS3KJbPhzc=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="345aa708-8178-4f3f-96e5-5b8da2c4d893"><source>The <x id="22" /> dynamically adjusts the charging policy based on the real-time load.</source><seg-source><mrk mtype="seg" mid="25">The <x id="22" /> dynamically adjusts the charging policy based on the real-time load.</mrk></seg-source><target><mrk mtype="seg" mid="25">De <x id="22" /> past het oplaadbeleid dynamisch aan op basis van de realtime belasting.</mrk></target><sdl:seg-defs><sdl:seg id="25"><sdl:value key="SegmentIdentityHash">5/OSDEZymypKUokTOw3k9ud5HSw=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="1" /><sdl:cxt id="2" /><sdl:cxt id="3" /></sdl:cxts><trans-unit id="5bc459e1-92ba-4772-b97c-a152319fe858"><source><g id="25">Economic optimization</g>:</source><seg-source><mrk mtype="seg" mid="26"><g id="25">Economic optimization</g>:</mrk></seg-source><target><mrk mtype="seg"